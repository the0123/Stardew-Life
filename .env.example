# Copy this to .env and fill in the values
# Never commit .env to git

# Postgres
POSTGRES_USER=stardewlife
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=stardewlife

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32

# CORS — JSON array of allowed origins (pydantic-settings requires JSON for list fields)
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# App environment: development or production
ENVIRONMENT=development

# JWT expiry
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Web Push (VAPID keys — leave blank until Phase 3)
# Generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('PRIVATE:', v.private_key); print('PUBLIC:', v.public_key)"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=your@email.com
